{
  "name": "tracker-ui",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development vite",
    "prebuild": "npm run test",
    "build": "VITE_BUILD_TIME=$(date -u +%Y-%m-%dT%H:%M:%SZ) sh -c \"tsc -b && vite build\"",
    "postbuild": "echo 'Build complete.' && find ./dist -name '*.js' -exec du -ch {} + | grep total",
    "lint": "eslint .",
    "test": "vitest run",
    "scenarios": "npx ts-node-esm scripts/run-mood-scenarios.ts",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler pages deploy ./dist"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toggle": "^1.1.10",
    "@tailwindcss/vite": "^4.1.17",
    "@tanstack/react-query": "^5.90.12",
    "@tanstack/react-router": "^1.157.17",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jsencrypt": "^3.5.4",
    "lucide-react": "^0.556.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.17"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tanstack/router-plugin": "^1.157.17",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "ts-node": "^10.9.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^4.1.2",
    "wrangler": "^4.53.0"
  }
}
